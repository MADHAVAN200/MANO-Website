# backend/.env.example
# Copy this file to .env and fill in your real values

# ── Required ──────────────────────────────────────────────────────────────────
# Get your free Groq API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Optional (defaults shown) ──────────────────────────────────────────────────
# Groq model to use
GROQ_MODEL=llama-3.3-70b-versatile

# Express server port
PORT=8001

# ChromaDB HTTP server URL (must be running separately — see below)
CHROMA_URL=http://localhost:8000

# Allowed frontend origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173

# ---------------- RAG Retrieval Tuning ----------------
# How many chunks to keep in final context
RAG_DEFAULT_TOP_K=24

# Max chunks fetched from vector DB before reranking
RAG_MAX_RETRIEVAL_K=40

# Minimum retrieval depths by question type
RAG_MIN_LOCATION_RETRIEVAL_K=30
RAG_MIN_GENERAL_RETRIEVAL_K=32

# Distance thresholds used before reranking
RAG_LOCATION_DISTANCE_THRESHOLD=1.8
RAG_GENERAL_DISTANCE_THRESHOLD=1.9

# Location-answer controls
RAG_LOCATION_RESULT_LIMIT=8
RAG_LOCATION_HINT_RETRIEVAL_K=25

# Hybrid ranking controls (semantic + keyword)
RAG_HYBRID_SEMANTIC_WEIGHT=0.7
RAG_HYBRID_KEYWORD_WEIGHT=0.3
RAG_HYBRID_MIN_SEMANTIC_SCORE=0.28
RAG_HYBRID_MIN_KEYWORD_SCORE=0.12
